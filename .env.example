# Copy this file to ".env" and fill in your own values.
# .env must sit in the project root (same folder as requirements.txt)

# ---- MySQL Database ----
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=leave_management_db

# ---- JWT ----
# Generate a strong random string for production, e.g. run:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=please_change_this_to_a_long_random_secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
